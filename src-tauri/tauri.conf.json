{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SEP Agent Workspace",
  "version": "0.1.0",
  "identifier": "com.sep.agentworkspace",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SEP Agent Workspace",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Desktop-first agent workspace",
    "longDescription": "A low-overhead desktop shell for single-session agent workflows with multi-provider routing, built-in tools, MCP, and transcript continuity."
  }
}
